{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DexuX Downloader",
  "version": "0.4.0",
  "identifier": "com.dexux.downloader",
  "build": {
    "beforeDevCommand": "npm run build",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist/renderer"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "DexuX Downloader",
        "width": 1180,
        "height": 860,
        "minWidth": 860,
        "minHeight": 620,
        "transparent": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["main"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "createUpdaterArtifacts": false
  }
}
