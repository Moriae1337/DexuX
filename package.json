{
  "name": "dexux-youtube-downloader",
  "productName": "DexuX Downloader",
  "version": "0.2.0",
  "description": "Electron and Python desktop app for downloading YouTube videos.",
  "main": "dist/electron/main.js",
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:backend": "node scripts/build-backend.mjs",
    "package:linux": "npm run build && node scripts/build-backend.mjs linux && electron-builder --linux AppImage --publish never",
    "package:win": "npm run build && node scripts/build-backend.mjs win32 && electron-builder --win nsis --publish never",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron ."
  },
  "build": {
    "appId": "com.dexux.downloader",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility",
      "extraResources": [
        {
          "from": "build-resources/backend/linux/downloader",
          "to": "backend/downloader"
        }
      ]
    },
    "win": {
      "target": [
        "nsis"
      ],
      "extraResources": [
        {
          "from": "build-resources/backend/win32/downloader.exe",
          "to": "backend/downloader.exe"
        }
      ]
    }
  },
  "devDependencies": {
    "@types/node": "^24.6.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.0.12",
    "typescript": "^5.9.3"
  }
}
