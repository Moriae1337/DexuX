{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "ignoreDeprecations": "6.0",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noEmitOnError": true,
    "rootDir": ".",
    "outDir": "dist"
  },
  "include": ["renderer/**/*.ts", "shared/**/*.d.ts"]
}
